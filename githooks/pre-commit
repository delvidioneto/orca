#!/bin/sh
# Atualiza o arquivo VERSION na raiz do projeto com versão semântica (ex.: v1.0.3).
# Se há commits após a última tag (ex.: v1.0.1-2-gHASH), o patch é incrementado -> v1.0.3.
# Instale: cp githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

ROOT=$(git rev-parse --show-toplevel)
VERSION_FILE="$ROOT/VERSION"
DESCRIBE=$(git describe --tags --long 2>/dev/null)

write_version() {
    echo "$1" > "$VERSION_FILE"
    git add "$VERSION_FILE" 2>/dev/null || true
}

if [ -z "$DESCRIBE" ]; then
    write_version "0.0.0"
    exit 0
fi

# Formato: TAG-N-gHASH (ex.: v1.0.1-2-g42256b6). Sed portável (sem -E) para Linux e macOS.
# Extrai TAG (tudo antes do último -N-g) e COMMITS (o número antes de -g)
TAG=$(echo "$DESCRIBE" | sed 's/-[0-9][0-9]*-g[0-9a-f][0-9a-f]*$//')
COMMITS=$(echo "$DESCRIBE" | sed 's/^.*-\([0-9][0-9]*\)-g[0-9a-f][0-9a-f]*$/\1/')

# Se a extração falhou (COMMITS não é numérico), usa 0.0.0
case "$COMMITS" in
    ''|*[!0-9]*) write_version "0.0.0"; exit 0 ;;
esac

# Se estamos exatamente na tag (0 commits), usa a tag
if [ "$COMMITS" = "0" ]; then
    write_version "$TAG"
    exit 0
fi

# Se a tag parece semver (vX.Y.Z com números), incrementa o patch
case "$TAG" in
    v[0-9]*.[0-9]*.[0-9]*)
        VER=${TAG#v}
        MAJOR=${VER%%.*}
        REST=${VER#*.}
        MINOR=${REST%%.*}
        PATCH=${REST#*.}
        [ -z "$PATCH" ] && PATCH=0
        PATCH=$((PATCH + COMMITS))
        write_version "v${MAJOR}.${MINOR}.${PATCH}"
        ;;
    *)
        write_version "$DESCRIBE"
        ;;
esac
exit 0
